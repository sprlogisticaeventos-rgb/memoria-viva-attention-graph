{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:memoria-viva:attention-graph:schema:constraint:1.0.0",
  "title": "Constraint",
  "description": "A sourced condition with explicit authority, uncertainty, privacy state, and temporal scope.",
  "x-schema-version": "1.0.0",
  "type": "object",
  "properties": {
    "schema_version": {"type": "string", "const": "1.0.0"},
    "constraint_id": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/repository_safe_reference"},
    "constraint_version": {"type": "integer", "minimum": 1},
    "condition": {"type": "string"},
    "authority_scope": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/authority_scope"},
    "authority_reference": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/nullable_repository_safe_reference"},
    "scope": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/string_list"},
    "status": {"type": "string", "enum": ["PROPOSED", "ACTIVE", "SATISFIED", "SUPERSEDED", "BLOCKED"]},
    "epistemic_state": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/epistemic_state"},
    "evidence_refs": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/nonempty_evidence_refs"},
    "uncertainty": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/uncertainty"},
    "privacy_classification": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/privacy_classification"},
    "effective_at": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/nullable_timestamp"},
    "expires_at": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/nullable_timestamp"},
    "supersedes_constraint_id": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/nullable_repository_safe_reference"}
  },
  "required": [
    "schema_version",
    "constraint_id",
    "constraint_version",
    "condition",
    "authority_scope",
    "authority_reference",
    "scope",
    "status",
    "epistemic_state",
    "evidence_refs",
    "uncertainty",
    "privacy_classification",
    "effective_at",
    "expires_at",
    "supersedes_constraint_id"
  ],
  "additionalProperties": false
}
