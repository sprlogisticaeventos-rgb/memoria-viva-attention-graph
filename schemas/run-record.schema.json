{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:memoria-viva:attention-graph:schema:run-record:1.0.0",
  "title": "RunRecord",
  "description": "The immutable audit receipt for one Memoria Viva transition, including deterministic replay identities, approvals, unresolved questions, claim evidence, and privacy state.",
  "x-schema-version": "1.0.0",
  "type": "object",
  "properties": {
    "schema_version": {"type": "string", "const": "1.0.0"},
    "run_id": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/repository_safe_reference"},
    "run_version": {"type": "integer", "minimum": 1},
    "execution_mode": {"type": "string", "enum": ["REPLAY", "MODEL"]},
    "started_at": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/timestamp"},
    "completed_at": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/nullable_timestamp"},
    "input_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/artifact_identity"}
    },
    "output_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/artifact_identity"}
    },
    "replay_input_identity": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/artifact_identity"},
    "replay_output_identity": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/artifact_identity"},
    "previous_snapshot_id": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/repository_safe_reference"},
    "new_snapshot_id": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/repository_safe_reference"},
    "trigger_event_id": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/repository_safe_reference"},
    "goal_ids": {
      "type": "array",
      "items": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/repository_safe_reference"},
      "uniqueItems": true
    },
    "source_ids": {
      "type": "array",
      "items": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/repository_safe_reference"},
      "uniqueItems": true
    },
    "graph_delta_id": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/repository_safe_reference"},
    "ranking_before_id": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/repository_safe_reference"},
    "ranking_after_id": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/repository_safe_reference"},
    "observations": {
      "type": "array",
      "items": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/run_observation"}
    },
    "recommendations": {
      "type": "array",
      "items": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/run_recommendation"}
    },
    "validations": {
      "type": "array",
      "items": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/run_validation"}
    },
    "warnings": {
      "type": "array",
      "items": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/run_warning"}
    },
    "approvals": {
      "type": "array",
      "items": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/approval_record"}
    },
    "unresolved_questions": {
      "type": "array",
      "items": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/unresolved_question"}
    },
    "decision_refs": {
      "type": "array",
      "items": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/lightweight_reference"}
    },
    "blocker_refs": {
      "type": "array",
      "items": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/lightweight_reference"}
    },
    "artifact_refs": {
      "type": "array",
      "items": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/lightweight_reference"}
    },
    "official_rules_verification": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/verification_claim"},
    "claim_states": {
      "type": "object",
      "properties": {
        "compliance": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/verification_claim"},
        "submission_completion": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/verification_claim"},
        "goal_completion": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/verification_claim"},
        "displacement_execution": {
          "type": "object",
          "properties": {
            "execution_state": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/execution_state"},
            "evidence_refs": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/evidence_refs"},
            "validation_refs": {
              "type": "array",
              "items": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/repository_safe_reference"},
              "uniqueItems": true
            },
            "explanation": {"type": "string"}
          },
          "required": ["execution_state", "evidence_refs", "validation_refs", "explanation"],
          "allOf": [
            {
              "if": {"properties": {"execution_state": {"const": "EXECUTED"}}, "required": ["execution_state"]},
              "then": {
                "properties": {
                  "evidence_refs": {"minItems": 1},
                  "validation_refs": {"minItems": 1}
                }
              }
            }
          ],
          "additionalProperties": false
        }
      },
      "required": ["compliance", "submission_completion", "goal_completion", "displacement_execution"],
      "additionalProperties": false
    },
    "status": {"type": "string", "enum": ["planned", "running", "completed", "blocked", "failed", "invalid"]},
    "schema_versions": {
      "type": "array",
      "items": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/schema_reference"}
    },
    "ontology_version": {"type": "string"},
    "policy_id": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/repository_safe_reference"},
    "policy_version": {"type": "string"},
    "policy_digest": {"type": "string", "minLength": 1},
    "privacy_classification": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/privacy_classification"},
    "privacy_review_state": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/privacy_review_state"},
    "model_metadata": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "provider": {"type": "string"},
            "model": {"type": "string"},
            "response_id": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/nullable_repository_safe_reference"},
            "reasoning_context": {"type": ["string", "null"]}
          },
          "required": ["provider", "model", "response_id", "reasoning_context"],
          "additionalProperties": false
        },
        {"type": "null"}
      ]
    }
  },
  "required": [
    "schema_version",
    "run_id",
    "run_version",
    "execution_mode",
    "started_at",
    "completed_at",
    "input_artifacts",
    "output_artifacts",
    "replay_input_identity",
    "replay_output_identity",
    "previous_snapshot_id",
    "new_snapshot_id",
    "trigger_event_id",
    "goal_ids",
    "source_ids",
    "graph_delta_id",
    "ranking_before_id",
    "ranking_after_id",
    "observations",
    "recommendations",
    "validations",
    "warnings",
    "approvals",
    "unresolved_questions",
    "decision_refs",
    "blocker_refs",
    "artifact_refs",
    "official_rules_verification",
    "claim_states",
    "status",
    "schema_versions",
    "ontology_version",
    "policy_id",
    "policy_version",
    "policy_digest",
    "privacy_classification",
    "privacy_review_state",
    "model_metadata"
  ],
  "allOf": [
    {
      "if": {"properties": {"execution_mode": {"const": "REPLAY"}}, "required": ["execution_mode"]},
      "then": {"properties": {"model_metadata": {"type": "null"}}},
      "else": {"properties": {"model_metadata": {"not": {"type": "null"}}}}
    }
  ],
  "additionalProperties": false
}
