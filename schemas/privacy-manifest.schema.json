{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:memoria-viva:attention-graph:schema:privacy-manifest:1.0.0",
  "title": "PrivacyManifest",
  "description": "Field-level sanitization, provenance, review, publication-surface approval, and residual aggregation-risk contract for a public fixture.",
  "x-schema-version": "1.0.0",
  "type": "object",
  "properties": {
    "schema_version": {"type": "string", "const": "1.0.0"},
    "manifest_id": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/repository_safe_reference"},
    "manifest_version": {"type": "string"},
    "fixture_identity": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/artifact_identity"},
    "source_classes": {
      "type": "array",
      "items": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/source_class"},
      "uniqueItems": true
    },
    "field_transformations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "field_scope": {"type": "string"},
          "original_class": {
            "type": "string",
            "description": "Classification of the field before sanitization. PRIVATE_TEMPORAL_DATA covers private temporal information whose exact chronology must not be exposed.",
            "enum": ["PUBLIC", "PRIVATE_CONTEXT", "PERSONAL_DATA", "SENSITIVE_DATA", "RAW_LOCATOR", "PRIVATE_TIMESTAMP", "PRIVATE_TEMPORAL_DATA", "SOURCE_TEXT", "SYNTHETIC_INPUT"]
          },
          "transformation_action": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/transformation_action"},
          "sanitized_class": {
            "type": "string",
            "description": "Classification after sanitization. INDEPENDENT_SYNTHETIC_COARSE_TIME is public-safe temporal data independently synthesized to preserve only required ordering, overlap, or urgency semantics without preserving one recoverable offset or exact private durations.",
            "enum": ["PUBLIC_SAFE_KEPT", "GENERALIZED", "PSEUDONYMIZED", "REMOVED", "SHIFTED_TIME", "SYNTHETIC", "INDEPENDENT_SYNTHETIC_COARSE_TIME"]
          },
          "reason": {"type": "string"},
          "source_derived": {"type": "boolean"},
          "reversible": {"type": "boolean", "const": false},
          "permitted_in_repository": {"type": "boolean"},
          "publication_approvals": {
            "type": "array",
            "items": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/publication_approval"},
            "minItems": 1
          },
          "privacy_review_state": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/privacy_review_state"},
          "founder_approval_state": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/approval_state"},
          "publication_approval_state": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/approval_state"},
          "evidence_refs": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/evidence_refs"}
        },
        "required": [
          "field_scope",
          "original_class",
          "transformation_action",
          "sanitized_class",
          "reason",
          "source_derived",
          "reversible",
          "permitted_in_repository",
          "publication_approvals",
          "privacy_review_state",
          "founder_approval_state",
          "publication_approval_state",
          "evidence_refs"
        ],
        "additionalProperties": false
      }
    },
    "publication_approvals": {
      "type": "array",
      "items": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/publication_approval"},
      "minItems": 1
    },
    "privacy_review_state": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/privacy_review_state"},
    "founder_approval_state": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/approval_state"},
    "publication_approval_state": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/approval_state"},
    "residual_aggregation_risk": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/residual_aggregation_risk"},
    "reviewer_reference": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/nullable_repository_safe_reference"},
    "approval_artifact_reference": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/nullable_repository_safe_reference"},
    "warnings": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/string_list"},
    "prohibited_content_confirmation": {
      "type": "object",
      "properties": {
        "no_raw_locators": {"type": "boolean", "const": true},
        "no_secrets": {"type": "boolean", "const": true},
        "no_unnecessary_personal_data": {"type": "boolean", "const": true},
        "no_reversible_mappings": {"type": "boolean", "const": true},
        "no_raw_source_text": {"type": "boolean", "const": true}
      },
      "required": ["no_raw_locators", "no_secrets", "no_unnecessary_personal_data", "no_reversible_mappings", "no_raw_source_text"],
      "additionalProperties": false
    },
    "created_at": {"$ref": "urn:memoria-viva:attention-graph:schema:common:1.0.0#/$defs/timestamp"}
  },
  "required": [
    "schema_version",
    "manifest_id",
    "manifest_version",
    "fixture_identity",
    "source_classes",
    "field_transformations",
    "publication_approvals",
    "privacy_review_state",
    "founder_approval_state",
    "publication_approval_state",
    "residual_aggregation_risk",
    "reviewer_reference",
    "approval_artifact_reference",
    "warnings",
    "prohibited_content_confirmation",
    "created_at"
  ],
  "additionalProperties": false
}
